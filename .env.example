# === 기상청 API허브 동네예보 단기예보 격자자료 ===
# nph-dfs_shrt_grd 요청의 authKey. 공공데이터포털 serviceKey는 사용하지 않습니다.
# 키 상태가 "정상"이어도 "동네예보 단기예보 격자자료" 활용신청 승인이 별도로 필요합니다.
KMA_AUTH_KEY=

# === 재난안전데이터공유플랫폼 (safetydata.go.kr) — 서비스별 키 분리 ===
# 재난문자(속보) DSSP-IF-10748 서비스키
SAFETYDATA_SERVICE10748_KEY=
# 긴급재난문자 DSSP-IF-00247 서비스키
SAFETYDATA_SERVICE00247_KEY=
# 통합대피소 DSSP-IF-10941 전용 serviceKey. 해당 API 이용신청 승인 후 서버 비밀값으로 등록합니다.
# https://www.safetydata.go.kr/V2/api/DSSP-IF-10941 호출에만 사용하며 다른 서비스 키로 폴백하지 않습니다.
SAFETYDATA_SERVICE10941_KEY=

# === 통합대피소 JSON 영속 저장소 ===
# Vercel Blob 스토어를 프로젝트에 연결하면 생성되는 서버 비밀 토큰입니다.
# 운영에서는 필수이며, 로컬 개발에서는 미설정 시 data/runtime JSON 파일을 사용합니다.
BLOB_READ_WRITE_TOKEN=

# === 카카오 ===
# 서버(REST) 키 - 장소검색/좌표변환 등 서버사이드 호출용, 절대 클라이언트에 노출 금지
KAKAO_REST_API_KEY=
# 클라이언트(JS SDK) 공개 키 - 브라우저 번들에 포함되므로 비밀값이 아닙니다.
# 카카오맵 사용 설정을 ON으로 하고 JavaScript SDK 도메인에 localhost와 운영 도메인을 제한 등록합니다.
# NEXT_PUBLIC_ 값은 빌드 시 반영되므로 Vercel에서 수정한 뒤 반드시 재배포합니다.
NEXT_PUBLIC_KAKAO_JS_KEY=

# === bizrouter (OpenAI 호환 게이트웨이) ===
# 공식 OpenAI 호환 기본 주소입니다. 미설정해도 이 주소를 사용합니다.
BIZROUTER_BASE_URL=https://api.bizrouter.ai/v1
BIZROUTER_API_KEY=
# BizRouter 모델 ID는 provider/model 형식을 사용합니다.
BIZROUTER_CHAT_MODEL=openai/gpt-4o-mini
BIZROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# === 관리자 콘솔 ===
# 별도 환경변수 없이 /admin/login에서 고정 접근코드 21002100을 입력합니다.
