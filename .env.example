# === 기상청 API 허브 (apihub.kma.go.kr) ===
KMA_AUTH_KEY=

# === 재난안전데이터포털 (safetydata.go.kr) — 서비스별 키 분리 ===
# 재난문자(속보) DSSP-IF-10748 서비스키
SAFETYDATA_SERVICE10748_KEY=
# 긴급재난문자 DSSP-IF-00247 서비스키
SAFETYDATA_SERVICE00247_KEY=
# (공용/레거시) 대피소 등 기타 서비스용 — 위 키가 비어 있으면 이 키로 폴백
SAFETYDATA_SERVICE_KEY=

# === 카카오 ===
# 서버(REST) 키 - 장소검색/좌표변환 등 서버사이드 호출용, 절대 클라이언트에 노출 금지
KAKAO_REST_API_KEY=
# 클라이언트(JS SDK) 키 - 지도 렌더링용, 카카오 콘솔에서 도메인 제한 필수
NEXT_PUBLIC_KAKAO_JS_KEY=

# === bizrouter (OpenAI 호환 게이트웨이) ===
BIZROUTER_BASE_URL=
BIZROUTER_API_KEY=
# 사용할 모델명 (게이트웨이 쪽 정책에 맞게 조정)
BIZROUTER_CHAT_MODEL=gpt-4o-mini
BIZROUTER_EMBEDDING_MODEL=text-embedding-3-small

# === 관리자 콘솔 ===
# /admin 접근용 비밀번호 (미설정 시 기본값 21002100 사용 — 운영 배포 시 변경 권장)
ADMIN_PASSWORD=21002100
# 로그인 쿠키 서명용 임의의 긴 문자열 (openssl rand -hex 32 등으로 생성)
ADMIN_SESSION_SECRET=
