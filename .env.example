# === 기상청 API 허브 (apihub.kma.go.kr) ===
KMA_AUTH_KEY=

# === 재난안전데이터포털 (safetydata.go.kr) ===
SAFETYDATA_SERVICE_KEY=

# === 카카오 ===
# 서버(REST) 키 - 장소검색/좌표변환 등 서버사이드 호출용, 절대 클라이언트에 노출 금지
KAKAO_REST_API_KEY=
# 클라이언트(JS SDK) 키 - 지도 렌더링용, 카카오 콘솔에서 도메인 제한 필수
NEXT_PUBLIC_KAKAO_JS_KEY=

# === bizrouter (OpenAI 호환 게이트웨이) ===
BIZROUTER_BASE_URL=
BIZROUTER_API_KEY=
# 사용할 모델명 (게이트웨이 쪽 정책에 맞게 조정)
BIZROUTER_CHAT_MODEL=gpt-4o-mini
BIZROUTER_EMBEDDING_MODEL=text-embedding-3-small

# === 관리자 콘솔 ===
# /admin 접근용 비밀번호 (Supabase Auth 연동 전 임시 게이트)
ADMIN_PASSWORD=
# 로그인 쿠키 서명용 임의의 긴 문자열 (openssl rand -hex 32 등으로 생성)
ADMIN_SESSION_SECRET=
