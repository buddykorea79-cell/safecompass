# === 기상청 동네예보 — 공급자별 서버 키를 섞지 않습니다. ===
# API허브(apihub.kma.go.kr) authKey. 키 상태가 "정상"이어도
# "동네예보(초단기실황·초단기예보·단기예보) 조회" 활용신청 승인이 별도로 필요합니다.
KMA_AUTH_KEY=
# 공공데이터포털(apis.data.go.kr) serviceKey. API허브 실패 시 사용할 선택 fallback이며,
# KMA_AUTH_KEY를 복사해 넣지 않습니다. 비워 두면 공공데이터포털 fallback을 사용하지 않습니다.
KMA_SERVICE_KEY=

# === 재난안전데이터포털 (safetydata.go.kr) — 서비스별 키 분리 ===
# 재난문자(속보) DSSP-IF-10748 서비스키
SAFETYDATA_SERVICE10748_KEY=
# 긴급재난문자 DSSP-IF-00247 서비스키
SAFETYDATA_SERVICE00247_KEY=
# (공용/레거시) 대피소 등 기타 서비스용 — 위 키가 비어 있으면 이 키로 폴백
SAFETYDATA_SERVICE_KEY=

# === 카카오 ===
# 서버(REST) 키 - 장소검색/좌표변환 등 서버사이드 호출용, 절대 클라이언트에 노출 금지
KAKAO_REST_API_KEY=
# 클라이언트(JS SDK) 공개 키 - 브라우저 번들에 포함되므로 비밀값이 아닙니다.
# 카카오맵 사용 설정을 ON으로 하고 JavaScript SDK 도메인에 localhost와 운영 도메인을 제한 등록합니다.
# NEXT_PUBLIC_ 값은 빌드 시 반영되므로 Vercel에서 수정한 뒤 반드시 재배포합니다.
NEXT_PUBLIC_KAKAO_JS_KEY=

# === bizrouter (OpenAI 호환 게이트웨이) ===
BIZROUTER_BASE_URL=
BIZROUTER_API_KEY=
# 사용할 모델명 (게이트웨이 쪽 정책에 맞게 조정)
BIZROUTER_CHAT_MODEL=gpt-4o-mini
BIZROUTER_EMBEDDING_MODEL=text-embedding-3-small

# === 관리자 콘솔 ===
# /admin 접근용 비밀번호. 기본값이 없으며 두 관리자 변수가 모두 설정되어야 콘솔이 활성화됩니다.
ADMIN_PASSWORD=
# 로그인 쿠키 서명용 임의의 긴 문자열 (openssl rand -hex 32 등으로 생성)
ADMIN_SESSION_SECRET=
